PORT=1478
MONGO_URI=mongodb://127.0.0.1:27017/denta-cloud
JWT_SECRET=change-me
JWT_EXPIRES=7d
CLIENT_ORIGIN=http://localhost:5173

# AI Assistant — put real keys only in backend/.env (never commit secrets)
# Prefer OPENAI for reliability. Gemini keys usually start with AIza...
# Optional: ASSISTANT_PROVIDER=openai | gemini | local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ASSISTANT_PROVIDER=openai
