# Vercel — required for login (Project → Settings → Environment Variables)
# MONGO_URI=mongodb+srv://...
# JWT_SECRET=your_secret
# CLIENT_ORIGIN=https://denta-cloud-psi.vercel.app
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Option A (recommended): call a deployed backend directly from the frontend
# VITE_API_URL=https://evident.octosofttechnologies.in/api

# Option B: Vercel build-time proxy (/api/* -> your backend). Set this in Vercel env vars.
# API_URL=https://evident.octosofttechnologies.in
