# Vercel — required for login (Project → Settings → Environment Variables)
# MONGO_URI=mongodb+srv://...
# JWT_SECRET=your_secret
# CLIENT_ORIGIN=https://denta-cloud-psi.vercel.app
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: proxy to an external backend instead of Vercel serverless API
# API_URL=https://your-backend.onrender.com
